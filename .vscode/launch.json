{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (http)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/CleanArchitectureReference.Api/bin/Debug/net10.0/CleanArchitectureReference.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/CleanArchitectureReference.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5141"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(http://\\S+)",
        "uriFormat": "%s/swagger"
      }
    },
    {
      "name": ".NET Core Launch (https)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/CleanArchitectureReference.Api/bin/Debug/net10.0/CleanArchitectureReference.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/CleanArchitectureReference.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7171;http://localhost:5141"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https://\\S+)",
        "uriFormat": "%s/swagger"
      }
    }
  ]
}
